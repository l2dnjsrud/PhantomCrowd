# LLM Configuration (OpenAI-compatible API)
PC_LLM_API_KEY=your-api-key-here
PC_LLM_BASE_URL=https://api.openai.com/v1
PC_LLM_MODEL=gpt-4o-mini
PC_LLM_ANALYSIS_MODEL=gpt-4o

# Examples for other providers:
# Ollama (free, local) — RECOMMENDED for Korean:
#   PC_LLM_BASE_URL=http://localhost:11434/v1
#   PC_LLM_API_KEY=ollama
#   PC_LLM_MODEL=exaone3.5:7.8b
#   PC_LLM_ANALYSIS_MODEL=exaone3.5:7.8b
#
# Ollama (free, local) — English:
#   PC_LLM_MODEL=qwen2.5:7b
#   PC_LLM_ANALYSIS_MODEL=qwen2.5:7b
#
# Anthropic:
#   PC_LLM_BASE_URL=https://api.anthropic.com/v1
#   PC_LLM_API_KEY=sk-ant-...
#   PC_LLM_MODEL=claude-haiku-4-5-20251001
#   PC_LLM_ANALYSIS_MODEL=claude-sonnet-4-5-20241022
#
# Groq (fast):
#   PC_LLM_BASE_URL=https://api.groq.com/openai/v1
#   PC_LLM_API_KEY=gsk_...
#   PC_LLM_MODEL=llama-3.1-8b-instant
#   PC_LLM_ANALYSIS_MODEL=llama-3.1-70b-versatile

PC_DEBUG=false
PC_DEFAULT_AUDIENCE_SIZE=50
